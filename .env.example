# ── App secrets ───────────────────────────────────────────────
# Generate a strong random secret:  openssl rand -base64 32
JWT_SIGNING_KEY=
POSTGRES_PASSWORD=postgres
GRAFANA_PASSWORD=admin
VAULT_ROOT_TOKEN=root
REDIS_PASSWORD=redis

# ── LLM (DeepSeek powers the entire workforce) ────────────────
# The API key is a SECRET and does NOT live here. Put it in
#   .secrets/deepseek_api_key   (gitignored; see .secrets/README.md)
# It is mounted into llm-gateway as a Docker secret (/run/secrets/deepseek_api_key).
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Portal ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Services ──────────────────────────────────────────────────
NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
