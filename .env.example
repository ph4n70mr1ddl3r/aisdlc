# ── App secrets ───────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-in-prod
POSTGRES_PASSWORD=postgres
GRAFANA_PASSWORD=admin
VAULT_ROOT_TOKEN=root

# ── LLM (DeepSeek powers the entire workforce) ────────────────
# The API key is a SECRET and does NOT live here. Put it in
#   .secrets/deepseek_api_key   (gitignored; see .secrets/README.md)
# It is mounted into llm-gateway as a Docker secret (/run/secrets/deepseek_api_key).
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Portal ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
